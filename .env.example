# Database (Supabase session pooler)
# IMPORTANT: For Supabase pooler, DB_USER is usually `postgres.<project-ref>`.
DB_URL=jdbc:postgresql://aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DB_USER=postgres.your_project_ref
DB_PASSWORD=your_database_password
DB_POOL_MAX=10
DB_POOL_MIN=1
DB_CONNECTION_TIMEOUT_MS=30000
DB_MAX_LIFETIME_MS=1800000
DB_IDLE_TIMEOUT_MS=600000
DB_KEEPALIVE_MS=30000

# App
FRONTEND_URL=http://localhost:5173
FRONTEND_EXTRA_ORIGINS=
PORT=8080
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_MS=60000
SPRING_PROFILES_ACTIVE=local
AUTH_ACCESS_TOKEN_SECRET=smartship-dev-access-token-secret-change-me-32chars
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_REFRESH_COOKIE_NAME=SMARTSHIP_REFRESH
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=Lax
